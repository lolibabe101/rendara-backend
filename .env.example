# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string (Railway / Render / Supabase all provide this)
DATABASE_URL=postgresql://user:password@localhost:5432/rendara_db

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── FIRS API (swap sandbox → live when FIRS opens public API) ─────────────────
FIRS_API_URL=https://api.firs.gov.ng/einvoicing   # placeholder
FIRS_API_KEY=your_firs_api_key_here
FIRS_SANDBOX=true

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://app.rendara.ng

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── App ───────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
